{
  "name": "gpt-sin-alzheimer-desktop",
  "version": "0.7.0",
  "main": "desktop/main.js",
  "description": "Versión de escritorio de GPT sin Alzheimer",
  "author": "Alejandro Moreno Rivera",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "release": "rimraf ../builds/${productName}-${version}",
    "lint": "eslint . --ext .js"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.13.2",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5"
  },
  "build": {
    "appId": "com.gptsin.alzheimer",
    "productName": "GPT-sin-Alzheimer",
    "directories": {
      "app": ".",
      "output": "../builds/${productName}-${version}"
    },
    "files": [
      "app/**/*",
      "assets/**/*",
      "config/**/*",
      "data/**/*",
      "desktop/**/*",
      "gpt/**/*",
      "windows/**/*",
      "windows/**/*",
      "README.md",
      "PRIVACY.md",
      "LICENSE",
      "CHANGELOG.md"
    ],
    "asar": false,
    "win": {
      "target": "nsis",
      "icon": "../assets/gpt-sin-alzheimer.ico"
    }
  }
}
